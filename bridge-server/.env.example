# =============================================================================
# Bridge Server Configuration
# =============================================================================
# Copy this file to .env and fill in the values

# --- Server ---
HOST=0.0.0.0
PORT=54517
SECRET_TOKEN=change-me-to-a-random-secret

# --- Plane ---
PLANE_URL=http://localhost:54512
PLANE_WORKSPACE_SLUG=erp-roadmap
# Session cookie from browser after login (auto-refreshed if PLANE_PASSWORD is set)
PLANE_COOKIE_VALUE=
# Credentials for auto session refresh (optional, but recommended)
PLANE_EMAIL=admin@plane.local
PLANE_PASSWORD=

# --- Planka ---
PLANKA_URL=http://localhost:54513
PLANKA_API_TOKEN=

# --- BookStack ---
BOOKSTACK_URL=http://localhost:54515
BOOKSTACK_API_TOKEN_ID=
BOOKSTACK_API_TOKEN_SECRET=

# --- OpenObserve ---
OPENOBSERVE_URL=http://localhost:54514
OPENOBSERVE_ORG=default
OPENOBSERVE_STREAM=bridge_logs
OPENOBSERVE_LOGIN=root@example.com
OPENOBSERVE_PASSWORD=
