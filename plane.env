# Django Settings
DJANGO_SETTINGS_MODULE=plane.settings.production
DJANGO_SECRET_KEY=plane-secret-key-change-in-production-2026
DJANGO_DEBUG=0

# Database
DATABASE_URL=postgres://plane:plane@2026@postgres:5432/plane
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=plane
DATABASE_USER=plane
DATABASE_PASSWORD=plane@2026

# Redis
REDIS_URL=redis://:redis@2026@redis:6379
CELERY_BROKER_URL=redis://:redis@2026@redis:6379
CELERY_RESULT_BACKEND=redis://:redis@2026@redis:6379

# Minio/S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=plane
AWS_SECRET_ACCESS_KEY=plane@2026
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_BUCKET_NAME=plane
USE_MINIO=1

# Web URLs
WEB_URL=http://localhost:54512
SPACE_BASE_URL=http://localhost:54512/space
ADMIN_BASE_URL=http://localhost:54512/admin
API_BASE_URL=http://localhost:54512/api

# Proxy
NGINX_BACKEND_HOST=api
NGINX_BACKEND_PORT=8000
NGINX_FRONTEND_HOST=frontend
NGINX_FRONTEND_PORT=3000
NGINX_SPACE_HOST=space
NGINX_SPACE_PORT=3000
NGINX_ADMIN_HOST=admin
NGINX_ADMIN_PORT=3000
SITE_ADDRESS=:80
FILE_SIZE_LIMIT=104857600
BUCKET_NAME=plane
